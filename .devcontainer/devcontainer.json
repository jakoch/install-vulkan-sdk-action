// For format details, see https://aka.ms/devcontainer.json
{
  "name": "Debian",
  "build": {
    "dockerfile": "./Dockerfile",
    // sets the run context to this .devcontainer folder
    "context": "."
  },
  // Set container specific settings.json values on container create.
  "customizations": {
    // Configure properties specific to VS Code.
    "vscode": {
      // Add the IDs of extensions you want installed when the container is created.
      "extensions": [
        // EditorConfig
        "EditorConfig.EditorConfig",
        "firsttris.vscode-jest-runner",
        // biome
        "biomejs.biome",
        // Github Actions
        "github.vscode-github-actions",
        // jest
        "orta.vscode-jest"
      ]
    },
    "settings": {
      "extensions.ignoreRecommendations": true,
      "terminal.integrated.defaultProfile.linux": "zsh",
      "terminal.integrated.shell.linux": "/bin/zsh",
      // tell VSCode that you want the shell to be a login, interactive shell
      "terminal.integrated.shellArgs.linux": ["-l", "-i"]
    }
  },
  "remoteUser": "root"
}
